# ─────────────────────────────────────────────────────────────────────────────
# E2E Test Credentials
# This file is gitignored. Never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────
#
# Add one block per test role your project needs.
# Convention: TEST_{ABBREV}_USERNAME / TEST_{ABBREV}_PASSWORD
# The comment above each block (e.g., "# Admin") becomes the role key in auth.ts
#
# Example:
#
#   # Admin
#   TEST_ADMIN_USERNAME=admin@example.com
#   TEST_ADMIN_PASSWORD=your-password
#
#   # Regular User
#   TEST_USER_USERNAME=user@example.com
#   TEST_USER_PASSWORD=your-password
#
# Fill in your project's roles below, then re-run /e2e:create to continue.
# ─────────────────────────────────────────────────────────────────────────────
